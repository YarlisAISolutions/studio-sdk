{
  "name": "@yarlisai/studio-sdk",
  "version": "0.5.0",
  "description": "Yarlis Studio SDK - Execute workflows programmatically",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run build:tsc",
    "build:tsc": "tsc",
    "dev:watch": "tsc --watch",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ystudio",
    "ai",
    "workflow",
    "sdk",
    "api",
    "automation",
    "typescript"
  ],
  "author": "Yarlis AI",
  "license": "Apache-2.0",
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^3.0.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YarlisAISolutions/studio-sdk.git",
    "directory": "packages/ts-sdk"
  },
  "homepage": "https://mybotbox.com",
  "bugs": {
    "url": "https://github.com/YarlisAISolutions/studio-sdk/issues"
  }
}
